diff --git a/tests/test_purchase_states.py b/tests/test_purchase_states.py
new file mode 100644
index 0000000..eea9bdd
--- /dev/null
+++ b/tests/test_purchase_states.py
@@ -0,0 +1,120 @@
+"""Pruebas de estados de compra/pago y del enlace Compras ↔ Catálogo (Fase 2)."""
+
+from __future__ import annotations
+
+from src import purchase_states as ps
+from src.catalog_items import CatalogItem, add_item
+
+
+# ---------------------------------------------------------------------------
+# Transiciones de estado
+# ---------------------------------------------------------------------------
+
+def test_valid_purchase_transitions():
+    assert ps.can_transition(ps.PURCHASE_DRAFT, ps.PURCHASE_REQUESTED)
+    assert ps.can_transition(ps.PURCHASE_APPROVED, ps.PURCHASE_ORDERED)
+    assert ps.can_transition(ps.PURCHASE_ORDERED, ps.PURCHASE_PARTIAL)
+    assert ps.can_transition(ps.PURCHASE_PARTIAL, ps.PURCHASE_RECEIVED)
+    assert ps.can_transition(ps.PURCHASE_RECEIVED, ps.PURCHASE_CLOSED)
+
+
+def test_invalid_purchase_transitions():
+    # No se puede saltar de Borrador directo a Recibida.
+    assert not ps.can_transition(ps.PURCHASE_DRAFT, ps.PURCHASE_RECEIVED)
+    # Una compra cancelada o cerrada es terminal.
+    assert ps.next_states(ps.PURCHASE_CANCELLED) == ()
+    assert ps.next_states(ps.PURCHASE_CLOSED) == ()
+
+
+def test_next_states_from_ordered():
+    nxt = ps.next_states(ps.PURCHASE_ORDERED)
+    assert ps.PURCHASE_PARTIAL in nxt
+    assert ps.PURCHASE_RECEIVED in nxt
+    assert ps.PURCHASE_CANCELLED in nxt
+
+
+# ---------------------------------------------------------------------------
+# Validaciones
+# ---------------------------------------------------------------------------
+
+def test_validate_purchase_line_rejects_bad_values():
+    assert ps.validate_purchase_line(quantity=0)
+    assert ps.validate_purchase_line(quantity=-1)
+    assert ps.validate_purchase_line(quantity=5, unit_price=-2)
+    assert ps.validate_purchase_line(quantity=5, exchange_rate=0)
+
+
+def test_validate_purchase_line_accepts_good_values():
+    assert ps.validate_purchase_line(quantity=10, unit_price=3.5, exchange_rate=40.0) == []
+
+
+def test_validate_reception_blocks_over_receipt():
+    errors = ps.validate_reception(ordered=100, already_received=96, receiving_now=10)
+    assert any("pendiente" in e for e in errors)
+
+
+def test_validate_reception_allows_partial():
+    assert ps.validate_reception(ordered=100, already_received=0, receiving_now=40) == []
+
+
+def test_validate_reception_over_receipt_with_authorization():
+    assert ps.validate_reception(
+        ordered=100, already_received=96, receiving_now=10, allow_over_receipt=True
+    ) == []
+
+
+def test_validate_reception_rejects_zero():
+    assert ps.validate_reception(ordered=100, already_received=0, receiving_now=0)
+
+
+# ---------------------------------------------------------------------------
+# Enlace con el catálogo
+# ---------------------------------------------------------------------------
+
+def _add_article(item_id="ART1", sku="SKU1", name="Papel bond", unit="Resma") -> CatalogItem:
+    item = CatalogItem(
+        item_id=item_id, sku=sku, name=name,
+        article_type="Material consumible", category="Papel y cartulina",
+        inventory_unit=unit,
+    )
+    add_item(item)
+    return item
+
+
+def test_catalog_purchase_options_lists_active_items():
+    _add_article()
+    options = ps.catalog_purchase_options()
+    assert len(options) == 1
+    label = next(iter(options))
+    assert "Papel bond" in label
+    assert options[label] == "ART1"
+
+
+def test_catalog_purchase_options_excludes_inactive_by_default():
+    add_item(CatalogItem(item_id="ART2", sku="SKU2", name="Viejo",
+                         article_type="Otro", category="Otro",
+                         inventory_unit="Unidad", active=False))
+    assert ps.catalog_purchase_options() == {}
+    assert len(ps.catalog_purchase_options(include_inactive=True)) == 1
+
+
+def test_resolve_purchase_article_by_id():
+    _add_article()
+    purchase = {"catalog_item_id": "ART1", "material_name": "Papel bond"}
+    resolved = ps.resolve_purchase_article(purchase)
+    assert resolved is not None
+    assert resolved.name == "Papel bond"
+
+
+def test_resolve_purchase_article_missing_returns_none():
+    assert ps.resolve_purchase_article({"catalog_item_id": "NOPE"}) is None
+    assert ps.resolve_purchase_article({}) is None
+
+
+def test_link_fields_keep_material_name_for_compat():
+    item = _add_article()
+    fields = ps.link_fields_for(item)
+    assert fields["catalog_item_id"] == "ART1"
+    assert fields["catalog_sku"] == "SKU1"
+    assert fields["material_name"] == "Papel bond"
+    assert fields["unit_name"] == "Resma"
