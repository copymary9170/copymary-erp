# Copia este archivo a ".env" y reemplaza los valores. NUNCA subas ".env"
# real a git (ya está en .gitignore) — contiene la contraseña de la base de
# datos de producción.

# Usuario y contraseña de PostgreSQL. Genera una contraseña larga y única,
# por ejemplo con: openssl rand -base64 24
POSTGRES_USER=copymary
POSTGRES_PASSWORD=cambia-esto-por-una-contrasena-larga-y-unica
POSTGRES_DB=copymary_erp
